# NOTE: a root .pubignore REPLACES the root .gitignore for publishing, so the
# relevant .gitignore rules are replicated here.

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter/Dart/Pub related
/pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
/build/
/coverage/

# Internal design/planning documents; not part of the published package.
docs/

# The demo GIF is served from GitHub in the README; 25 MB does not belong in
# the package archive. The PNG icon stays (pubspec screenshots).
screenshots/scroll_spy.gif
