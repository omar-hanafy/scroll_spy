# NOTE: a root .pubignore REPLACES the root .gitignore for publishing, so the
# relevant .gitignore rules are replicated here.

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter/Dart/Pub related
/pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
/build/
/coverage/

# Internal design/planning documents; not part of the published package.
docs/
brand/

# Repository-only product site and comparison benchmark.
website/
benchmark/

# The animated demo is served from GitHub in the README and does not belong in
# the package archive. The formal PNG screenshots stay.
screenshots/scroll_spy.gif

# Raw screen recordings (gitignored, but .pubignore replaces .gitignore, so
# without this line a locally built archive would include the 38 MB mp4).
screenshots/*.mp4

# AI coding-assistant plugin distribution (Claude Code / Codex). Installed
# from the GitHub repository, never from the pub.dev archive; shipping only
# the visible parts (hidden manifests are auto-excluded by pub) would produce
# a broken partial plugin, so the whole tree stays out.
plugins/
AGENTS.md
CLAUDE.md
tool/
