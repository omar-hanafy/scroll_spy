# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
/pubspec.lock
# The example is an app but its lockfile is not published and adds churn.
example/pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
/build/
/coverage/

# Raw screen recordings used to regenerate the demo GIF; kept local, too large for git.
screenshots/*.mp4
